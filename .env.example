# Copy to .env and adjust. docker-compose reads this automatically.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=rs

# REQUIRED: secret for signing JWTs (use a long random string)
JWT_SECRET=change-this-to-a-long-random-secret

# host port the app is published on
APP_PORT=8080

# raised per-session for the recommendation sort
RECOMMEND_WORK_MEM=64MB

# Postgres tuning (docker-compose.prod.yml). Calibrate to the VPS:
# PG_SHARED_BUFFERS ~25% of RAM, PG_EFFECTIVE_CACHE_SIZE ~75% of RAM.
PG_SHARED_BUFFERS=2GB
PG_EFFECTIVE_CACHE_SIZE=6GB
PG_WORK_MEM=32MB
PG_MAINTENANCE_WORK_MEM=1GB
PG_SHM_SIZE=1g

# kill any API query running longer than this (ms)
PG_STATEMENT_TIMEOUT_MS=30000

# Backup (docker-compose.prod.yml). Sem isso o dump fica SÓ no disco da VPS e
# falhas passam despercebidas — configure pelo menos o webhook.
# Webhook que recebe POST {"text": "..."} quando backup/offsite falha
# (Slack incoming webhook, Discord, ntfy.sh, etc.)
BACKUP_WEBHOOK_URL=
# Destino rclone p/ cópia externa (ex.: s3:meu-bucket/prospecta).
# Requer ./rclone/rclone.conf criado com `rclone config`.
BACKUP_RCLONE_REMOTE=

# Rate limit dos endpoints de autenticação (por IP)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute

# WhatsApp / Evolution API. A key é a AUTHENTICATION_API_KEY da Evolution (use uma
# longa e aleatória em produção). O webhook token valida os POSTs de entrada — o
# WHATSAPP_WEBHOOK_URL precisa carregar esse mesmo token na query (?token=...).
EVOLUTION_API_KEY=dev-evolution-key
WHATSAPP_WEBHOOK_TOKEN=dev-webhook-token
# Em produção (docker-compose.prod.yml) defina também, apontando pro app público:
# EVOLUTION_API_URL=http://evolution:8080
# WHATSAPP_WEBHOOK_URL=http://app:8080/api/webhooks/whatsapp?token=dev-webhook-token
# Mídia do WhatsApp em disco (volume) em vez de base64 no Postgres. Vazio = base64.
# Nos compose já vem setado pra /data/wa-media.
# WHATSAPP_MEDIA_DIR=/data/wa-media
